@using IdeaCollectionSystem.Service.Models.DTOs
@model QADashboardDto

@{
    ViewData["Title"] = "QA Dashboard";
}

<h2 class="mb-4">QA Manager Dashboard</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5>Total Ideas</h5>
                <h3>@Model.TotalIdeas</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5>Total Categories</h5>
                <h3>@Model.TotalCategories</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5>Total Departments</h5>
                <h3>@Model.TotalDepartments</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5>Ideas Without Comments</h5>
                <h3>@Model.IdeasWithoutComments</h3>
            </div>
        </div>
    </div>
</div>

<hr />

<div class="mt-4">
    <a asp-action="ExportCsv" class="btn btn-outline-primary">
        Export Ideas to CSV
    </a>

    <a asp-action="ExportZip" class="btn btn-outline-success">
        Download All Documents (ZIP)
    </a>

    <a asp-action="DepartmentStats" class="btn btn-outline-info">
        View Department Statistics
    </a>

    <a asp-action="IdeasWithoutComments" class="btn btn-outline-danger">
        View Ideas Without Comments
    </a>

    <a asp-action="Categories" class="btn btn-outline-dark">
        Manage Categories
    </a>
</div>