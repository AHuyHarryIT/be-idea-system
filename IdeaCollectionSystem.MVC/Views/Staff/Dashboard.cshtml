<div class="container py-4">
    <h3>Staff Workspace</h3>
    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="card border-primary h-100">
                <div class="card-body text-center">
                    <i class="bi bi-lightbulb fs-1 text-primary"></i>
                    <h5 class="mt-3">New Idea</h5>
                    <p class="small text-muted">Contribute to University improvements.</p>
                    <a asp-action="Terms" class="btn btn-primary w-100">Submit Now</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-person-badge fs-1"></i>
                    <h5 class="mt-3">My Contributions</h5>
                    <a asp-action="MyIdeas" class="btn btn-outline-secondary w-100">View My Ideas</a>
                </div>
            </div>
        </div>
    </div>
</div>